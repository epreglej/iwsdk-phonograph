<style>
  .outer-layer {
    width: 300px;
    max-width: 300px;
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-end;
    padding-top: 8px;
    padding-right: 8px;
  }

  .next-button {
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    border-radius: 22px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding-top: 12px;
    padding-bottom: 12px;
    padding-left: 12px;
    padding-right: 12px;
    background-color: rgb(24, 24, 26);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.35);
    margin-top: -21px;
    margin-right: -6px;
  }

  .next-button:hover {
    background-color: rgba(24, 24, 26, 0.96);
    border-color: rgba(255, 255, 255, 0.44);
  }

  .card {
    width: 280px;
    max-width: 280px;
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-radius: 22px;
    background-color: rgba(20, 20, 24, 0.92);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.18);
    padding-top: 18px;
    padding-bottom: 18px;
